OUTPUT_DIR=data/raw/youtube
LOG_DIR=runtime_single_test/logs
WORKER_TMP_PREFIX=/tmp/yt_worker_
RUNTIME_SUBDIR=runtime_single_test
URLS_FILENAME=urls.txt
ARCHIVE_FILENAME=downloaded.txt
NUM_WORKERS=1
REFRESH_SECONDS=5
BROWSER_SEQUENTIAL_MODE=1
AUTO_RESUME_ENABLED=1
AUTO_RESUME_COOLDOWN_SECONDS=12
AUTO_RESUME_MAX_ATTEMPTS=300
BASIC_AUTH_ENABLED=0
MAX_RETRIES=1
MIN_SLEEP=0
MAX_SLEEP=0
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
MIN_FILE_SIZE=1000
DOWNLOAD_FORMAT=18
STRICT_WAV_VALIDATION=1
WAV_CODEC=pcm_s16le
USE_COOKIES=0
PO_ARGS="--extractor-args youtube:player_client=android"
COOKIE_FILES="cookies_user.txt cookies_user.txt cookies_user.txt cookies_user.txt cookies_user.txt"
