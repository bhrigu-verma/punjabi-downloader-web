# Standalone YouTube downloader config
# Override with: export DOWNLOADER_CONFIG=/path/to/your.env

# Paths are relative to project root unless absolute
OUTPUT_DIR=data/raw/youtube
LOG_DIR=runtime/logs
WORKER_TMP_PREFIX=/tmp/yt_worker_

# Internal project paths (relative to project root)
RUNTIME_SUBDIR=runtime
URLS_FILENAME=urls.txt
ARCHIVE_FILENAME=downloaded.txt

# Parallelism and monitoring
NUM_WORKERS=10
REFRESH_SECONDS=5

# Browser behavior
BROWSER_SEQUENTIAL_MODE=0
AUTO_RESUME_ENABLED=1
AUTO_RESUME_COOLDOWN_SECONDS=12
AUTO_RESUME_MAX_ATTEMPTS=300

# Basic auth for dashboard/API (recommended for public deployments)
BASIC_AUTH_ENABLED=0
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASS=change-this-password

# Worker behavior
MAX_RETRIES=3
MIN_SLEEP=2
MAX_SLEEP=4
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
MIN_FILE_SIZE=1000
DOWNLOAD_FORMAT=bestaudio/best
STRICT_WAV_VALIDATION=0
WAV_CODEC=pcm_s16le

# YouTube anti-bot component
PO_ARGS=--remote-components ejs:github

# Cookie files expected in project root
# Worker mapping: 00/05 -> cookies.txt, 01/06 -> cookies1.txt, etc.
COOKIE_FILES="cookies.txt cookies1.txt cookies2.txt cookies3.txt cookies4.txt"
